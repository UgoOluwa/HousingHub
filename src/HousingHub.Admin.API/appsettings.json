{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "AdminJwt": {
    "Secret": "your-admin-jwt-secret-min-32-chars-replace-this",
    "Issuer": "HousingHub.Admin.API",
    "Audience": "HousingHub.Admin",
    "ExpirationInMinutes": 480
  },
  "AWS": {
    "DynamoDB": {
      "Region": "af-south-1"
    },
    "S3": {
      "BucketName": "housinghub-files-dev",
      "Region": "af-south-1"
    }
  }
}
